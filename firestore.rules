rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================
    // 🔒 프로덕션용 보안 규칙
    // 학급 경제 교육 앱에 맞춤 설정
    // ========================================================

    // 헬퍼 함수들
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      // SuperAdmin은 관리자 권한을 모두 포함
      // exists() 선검사로 문서 없는 유저의 오류 방지
      //
      // 🔒 isApproved == true 필수 (2026-07-14 Gemini 교차검증):
      //    교사 회원가입은 공개돼 있고 가입자가 isAdmin:true를 스스로 넣을 수 있다(create 규칙은
      //    isApproved:false이기만 하면 허용). 그런데 승인 여부를 아무도 검사하지 않아서,
      //    누구나 교사로 가입 → classCode를 남의 학급으로 변경 → 그 학급의 완전한 관리자가 될 수 있었다
      //    (classCode 자기 변경은 '학급 참여' 정상 기능이라 막을 수 없다 → 승인 게이트로 막는다).
      //    실측(2026-07-14): 운영 중인 정상 교사 5명 전원 isApproved == true. 슈퍼관리자는 아래 OR로 예외.
      return isSignedIn() &&
             userDocExists() &&
             ((get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isApproved', false) == true) ||
              isSuperAdmin());
    }

    function isSuperAdmin() {
      return isSignedIn() &&
             userDocExists() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isSuperAdmin', false) == true;
    }

    function getUserClassCode() {
      return userDocExists()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.classCode
        : '';
    }

    function isSameClass(classCode) {
      return isSignedIn() && getUserClassCode() == classCode;
    }

    // ========================================================
    // 🔥 읽기 전용 Fast 헬퍼 — Auth 커스텀 클레임 우선 단락평가로
    //    요청당 get(users/본인) 읽기 과금을 제거. 클레임 부재·불일치 시
    //    기존 문서 조회로 fallback하므로 동작 동일(fail-closed).
    //    클레임은 토큰 갱신(≤1h)까지 stale할 수 있으므로 "읽기" 규칙에만 쓰고,
    //    쓰기/생성/수정/삭제 규칙은 반드시 문서 기반 헬퍼(isSameClass/isAdmin/isSuperAdmin)를 유지한다.
    // ========================================================
    function isSameClassFast(classCode) {
      return isSignedIn() &&
             (('classCode' in request.auth.token && request.auth.token.classCode == classCode) ||
              getUserClassCode() == classCode);
    }

    function isAdminFast() {
      // 클레임 경로도 승인(isApproved) 검사 — 미승인 계정이 클레임만으로 통과하지 못하게 한다.
      // 클레임에 isApproved가 없으면(구 토큰) 이 분기는 false가 되고 아래 isAdmin() 문서조회로 fallback.
      return isSignedIn() &&
             (('isAdmin' in request.auth.token && request.auth.token.isAdmin == true &&
               'isApproved' in request.auth.token && request.auth.token.isApproved == true) ||
              ('isSuperAdmin' in request.auth.token && request.auth.token.isSuperAdmin == true) ||
              isAdmin());
    }

    function isSuperAdminFast() {
      return isSignedIn() &&
             (('isSuperAdmin' in request.auth.token && request.auth.token.isSuperAdmin == true) ||
              isSuperAdmin());
    }

    // 🚨 경찰서 신고의 '당사자 신원' 필드는 생성 후 불변.
    //    합의금이 이 필드(피해자=victimId, 가해자=defendantId)를 기준으로 서버에서 지급되므로,
    //    같은 반 학생이 지급 직전에 update로 피해자를 바꿔치기해 합의금을 가로채는 것을 막는다.
    //    (접수·벌금 처리는 status·amount 등만 바꾸므로 이 동결에 영향받지 않는다.
    //     합의금 지급 CF는 Admin SDK라 규칙을 우회해 필요한 필드를 갱신할 수 있다.)
    function policeReportIdentityFrozen() {
      return request.resource.data.get('reporterId', '') == resource.data.get('reporterId', '') &&
             request.resource.data.get('complainantId', '') == resource.data.get('complainantId', '') &&
             request.resource.data.get('defendantId', '') == resource.data.get('defendantId', '') &&
             request.resource.data.get('reportedUserId', '') == resource.data.get('reportedUserId', '') &&
             request.resource.data.get('victimId', '') == resource.data.get('victimId', '');
    }

    // 🚨 신고 '생성' 시 신원 검증 — update 동결만으로는 부족하다. 검증 없는 create를 열어두면
    //    학생이 victimId=자기, defendantId=타겟(또는 빈값)인 위조 신고를 새로 만들어 합의금을
    //    자기에게 유도할 수 있다(codex 2026-07-15). 그래서 생성 자체를 다음으로 제약한다:
    //     · 신고자는 반드시 본인(reporterId==uid), 고소인도 본인
    //     · 합의금 수령 대상(victimId)에 자기 자신을 지정 금지 — 자기지급 원천 차단
    //     · 가해자(defendantId)는 존재하는 문자열이고 본인이 아님(→ 서버 senderId 파생이 항상 유효)
    function policeReportCreateValid() {
      return request.resource.data.get('reporterId', '') == request.auth.uid &&
             request.resource.data.get('complainantId', request.auth.uid) == request.auth.uid &&
             request.resource.data.get('defendantId', '') is string &&
             request.resource.data.get('defendantId', '') != '' &&
             request.resource.data.get('defendantId', '') != request.auth.uid &&
             request.resource.data.get('victimId', '') != request.auth.uid;
    }

    // 문자열 길이 검증 헬퍼
    function isValidString(value, maxLen) {
      return value is string && value.size() <= maxLen;
    }

    function isValidNumber(value, min, max) {
      return value is number && value >= min && value <= max;
    }

    // 데이터 유효성 검증
    function isValidUserData() {
      return request.resource.data.keys().hasAll(['name', 'classCode', 'cash', 'coupons']) &&
             request.resource.data.cash >= 0 &&
             request.resource.data.coupons >= 0;
    }

    // ========================================================
    // 📁 users 컬렉션
    // ========================================================
    match /users/{userId} {
      // 읽기: 본인, 같은 학급, 관리자, 또는 SuperAdmin (전체 목록 조회용)
      allow read: if isOwner(userId) || isSameClassFast(resource.data.classCode) || isAdminFast() || isSuperAdminFast();

      // 생성: 본인만 (회원가입)
      // - isSuperAdmin은 절대 자체 설정 불가
      // - isAdmin/isTeacher로 가입할 경우 반드시 isApproved:false 강제 (셀프 승인 차단)
      //   슈퍼관리자가 별도로 isApproved:true로 승격해야 활성화됨
      //
      // 🔒 create 경로도 권한 필드를 막는다 (2026-07-14 codex 교차검증):
      //    update만 막으면 학생이 '자기 문서 delete → 권한 필드를 넣어 재생성'으로 우회할 수 있었다
      //    (allow delete: isOwner). 가입 시 직업·위임권한은 항상 비어 있어야 정상이므로,
      //    이 필드들이 아예 없거나 빈 값일 때만 생성을 허용한다. 관리자는 아래 isAdmin() 분기로 예외.
      allow create: if isAdmin() ||
                      (isOwner(userId) && isValidUserData() &&
                       !request.resource.data.get('isSuperAdmin', false) &&
                       (
                         (
                           !request.resource.data.get('isAdmin', false) &&
                           !request.resource.data.get('isTeacher', false)
                         )
                         ||
                         request.resource.data.isApproved == false
                       ) &&
                       request.resource.data.get('selectedJobIds', []).size() == 0 &&
                       request.resource.data.get('appointedJobIds', []).size() == 0 &&
                       !('delegatedPermissions' in request.resource.data) &&
                       !('jobName' in request.resource.data) &&
                       !('jobTitle' in request.resource.data) &&
                       (!('nickname' in request.resource.data) || isValidString(request.resource.data.nickname, 20)) &&
                       isValidString(request.resource.data.name, 50));

      // 수정: 본인, 같은 학급, 또는 관리자
      // - 본인: 중요 필드(isAdmin, isSuperAdmin, classCode) 제외 모든 필드 수정 가능
      // - 같은 학급: cash, updatedAt 필드만 수정 가능 (송금, 벌금 등)
      // - 관리자: 모든 필드 수정 가능
      //
      // 🔒 selectedJobIds / appointedJobIds 는 본인 write 금지 (2026-07-13 FULL 교차검증):
      //    학생이 대통령 등 지정 전용 직업 id를 직접 써넣어 주급 보너스(+200만/주)와
      //    할일 승인·법안 거부권을 자가 획득할 수 있었다. 이제 학생의 직업 선택은
      //    saveSelectedJobs callable(서버 검증: 존재·학급·지정전용 배제·중복 제거·상한)이
      //    유일한 경로이고, 지정 전용 직업은 교사(관리자)만 appointedJobIds에 넣을 수 있다.
      //    delegatedPermissions도 같은 이유로 차단 — 학생이 taskApproval:true를 self-grant 하면
      //    직업 경로를 막아도 같은 권한(할일 승인)을 그대로 얻는다(functions/index.js processTaskApproval).
      //
      // 🔒 일일 한도 카운터(dailyItemUse·dailyItemBuy·dailyDrawCount·dailyDrawDate)도 본인 write 금지:
      //    서버(useUserItem·drawRandomItem 등)가 이 값을 한도 판정에 그대로 신뢰하는데 학생이 스스로
      //    지울 수 있어 하루 사용/구매/뽑기 한도를 무제한 우회할 수 있었다. 클라이언트는 이 필드를
      //    읽지도 쓰지도 않는다(CF 전용 카운터) — 차단해도 정상 기능에 영향 없음(2026-07-14 실측).
      allow update: if (isOwner(userId) &&
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isSuperAdmin', 'isTeacher', 'isApproved', 'role', 'selectedJobIds', 'appointedJobIds', 'jobName', 'jobTitle', 'delegatedPermissions', 'dailyItemUse', 'dailyItemBuy', 'dailyDrawCount', 'dailyDrawDate']) &&
                        // 필드 유효성 검증
                        (!('nickname' in request.resource.data) || isValidString(request.resource.data.nickname, 20)) &&
                        (!('cash' in request.resource.data) || request.resource.data.cash is number) &&
                        (!('coupons' in request.resource.data) || request.resource.data.coupons is number)) ||
                       (isSameClass(resource.data.classCode) &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cash', 'updatedAt', 'lastIncomingTransferAt']) &&
                        request.resource.data.cash is number) ||
                       isAdmin();

      // 삭제: 본인 또는 관리자
      allow delete: if isOwner(userId) || isAdmin();

      // ========================================================
      // 💰 거래 기록 서브컬렉션 (users/{userId}/transactions/{transactionId})
      // ========================================================
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdminFast();
        // 생성: 본인 또는 같은 학급 사용자 (송금 시 상대방 거래 기록 생성 가능)
        allow create: if isOwner(userId) ||
                         (isSignedIn() &&
                          isSameClass(get(/databases/$(database)/documents/users/$(userId)).data.classCode));
        allow update: if false; // 거래 기록은 수정 불가
        allow delete: if isAdmin();
      }

      // ========================================================
      // 📈 주식 포트폴리오 서브컬렉션 (users/{userId}/portfolio/{stockId})
      // ========================================================
      match /portfolio/{stockId} {
        allow read: if isOwner(userId) || isSameClassFast(get(/databases/$(database)/documents/users/$(userId)).data.classCode) || isAdminFast();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ========================================================
      // 📦 인벤토리 서브컬렉션 (users/{userId}/inventory/{itemId})
      // ========================================================
      // 📅 메타 서브컬렉션 (출석 스트릭 등)
      match /meta/{metaId} {
        allow read: if isOwner(userId) || isAdminFast();
        allow write: if isOwner(userId) || isAdmin();
      }

      match /inventory/{itemId} {
        // 읽기: 본인, 관리자, 또는 같은 학급 사용자 (아이템 선물 기능을 위해)
        allow read: if isOwner(userId) || isAdminFast() || (isSignedIn() && isSameClassFast(get(/databases/$(database)/documents/users/$(userId)).data.classCode));
        // 쓰기: 본인, 관리자만. 선물은 giftItem CF(Admin SDK)가 서버에서 원자 처리.
        // ⚠️ 2026-07-10 사건: 같은 학급 전체 write 허용이 "무기록 아이템 이동/증발"의 통로였음 — 재개방 금지.
        allow write: if isOwner(userId) || isAdmin();
      }

      // ========================================================
      // 🎯 완료된 과제 서브컬렉션 (users/{userId}/completedTasks/{taskId})
      // ========================================================
      match /completedTasks/{taskId} {
        allow read: if isOwner(userId) || isAdminFast();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ========================================================
      // 💰 금융 정보 서브컬렉션 (users/{userId}/financials/{document})
      // ========================================================
      match /financials/{document} {
        allow read: if isOwner(userId) || isAdminFast();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ========================================================
      // 📦 가입 상품 서브컬렉션 (users/{userId}/products/{productId})
      // ========================================================
      match /products/{productId} {
        allow read: if isOwner(userId) || isAdminFast();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ========================================================
      // 💸 대출 서브컬렉션 (users/{userId}/loans/{loanId})
      // ========================================================
      match /loans/{loanId} {
        allow read: if isOwner(userId) || isAdminFast();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ========================================================
      // ⚙️ 사용자 설정 서브컬렉션 (users/{userId}/settings/{settingId})
      // 튜토리얼 상태, 테마 등 사용자 개인 설정
      // ========================================================
      match /settings/{settingId} {
        allow read: if isOwner(userId) || isAdminFast();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ========================================================
      // 🏅 배지 서브컬렉션 (users/{userId}/badges/{document})
      // ========================================================
      match /badges/{document} {
        allow read: if isOwner(userId) || isAdminFast();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ========================================================
      // 🏠 부동산 서브컬렉션 (users/{userId}/properties/{propertyId})
      // ========================================================
      match /properties/{propertyId} {
        allow read: if isOwner(userId) || isAdminFast();
        allow write: if isOwner(userId) || isAdmin();
      }

      // ========================================================
      // 📋 활동 로그 서브컬렉션 (users/{userId}/activityLogs/{logId})
      // 경매 낙찰/유찰 등 활동 기록
      // ========================================================
      match /activityLogs/{logId} {
        allow read: if isOwner(userId) || isAdminFast();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
      }
    }

    // ========================================================
    // 📈 주식 포트폴리오 (ClassStock/{classCode}/portfolio/{userId})
    // ========================================================
    match /ClassStock/{classCode}/portfolio/{userId} {
      allow read: if isSameClassFast(classCode) || isAdminFast();
      allow write: if isOwner(userId) || isAdmin();

      match /holdings/{holdingId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // ========================================================
    // 👨‍🎓 학생 데이터 (ClassStock/{classCode}/students/{userId})
    // ========================================================
    match /ClassStock/{classCode}/students/{userId} {
      allow read: if isSameClassFast(classCode) || isAdminFast();
      allow write: if isOwner(userId) || isAdmin();

      // 부동산 서브컬렉션
      match /realestates/{estateId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow write: if isOwner(userId) || isAdmin();
      }

      // 파킹통장 서브컬렉션
      match /parkingAccounts/{accountId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // ========================================================
    // 💹 주식 정보 (ClassStock/{classCode}/stocks/{stockId})
    // ========================================================
    match /ClassStock/{classCode}/stocks/{stockId} {
      allow read: if isSameClassFast(classCode);
      allow write: if isAdmin();
    }

    // ========================================================
    // 📰 뉴스 (ClassStock/{classCode}/news/{newsId})
    // ========================================================
    match /ClassStock/{classCode}/news/{newsId} {
      allow read: if isSameClassFast(classCode);
      allow write: if isAdmin();
    }

    // ========================================================
    // 🏢 중앙 주식 시장 (CentralStocks)
    // ========================================================
    match /CentralStocks/{stockId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /CentralNews/{newsId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ========================================================
    // 📊 시장 상황 (MarketCondition)
    // ========================================================
    match /MarketCondition/{conditionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ========================================================
    // 🏪 상점 아이템 (storeItems)
    // ========================================================
    match /storeItems/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ========================================================
    // 🏪 카탈로그 버전 (catalogMeta) — 상점 변경 실시간 전파용.
    //    학생은 같은 학급 문서 1개만 onSnapshot으로 읽음.
    //    쓰기는 Cloud Function(Admin SDK, rules 우회) 전용.
    // ========================================================
    match /catalogMeta/{classCode} {
      allow read: if isSameClassFast(classCode);
      allow write: if false;
    }

    // ========================================================
    // 🎭 아바타 상점 아이템 (avatarShopItems) - 전 학급 공용
    // ========================================================
    match /avatarShopItems/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ========================================================
    // 🛒 마켓 아이템 (marketItems)
    // ========================================================
    match /marketItems/{listingId} {
      // 읽기: 같은 학급만 (판매자 정보 타 학급 노출 방지)
      allow read: if isSameClassFast(resource.data.classCode) || isAdminFast();
      allow create: if isSignedIn() && isOwner(request.resource.data.sellerId);
      allow update: if isSignedIn() &&
                       (isOwner(resource.data.sellerId) ||
                        isOwner(resource.data.buyerId) ||
                        isAdmin());
      allow delete: if isOwner(resource.data.sellerId) || isAdmin();
    }

    // ========================================================
    // 📝 활동 로그 (activity_logs)
    // ========================================================
    match /activity_logs/{logId} {
      allow read: if isSignedIn() && (isSameClassFast(resource.data.classCode) || isAdminFast());
      // 🔥 완화 (2026-05): 거래 양쪽 모두 같은 트랜잭션에서 로그 생성 필요
      //   기존: 본인 로그만 → 송금/경매/상점 상대방 로그가 생성 안 되어 트랜잭션 실패
      //   변경: 같은 학급이면 누구 userId의 로그도 생성 가능. 단 metadata 검증으로 악용 차단:
      //         · classCode = 본인 학급 (타 학급 로그 위조 차단)
      //         · userId is string (필수)
      //         · description ≤ 500자 (스팸 차단)
      //         · amount는 number이고 ±100억 이하 (비현실적 금액 차단)
      //           (2026-06-12: ±1억 → ±100억 상향. 학급경제 인플레이션으로 함께구매 잔여액이
      //            1억을 초과하면 기여 트랜잭션 전체가 거부되는 실사고 발생 — 자유시간 가격은
      //            완료마다 2배 인상되어 다음 캠페인은 3.2억)
      allow create: if isAdmin() ||
                       (isSignedIn() &&
                       request.resource.data.classCode == getUserClassCode() &&
                       request.resource.data.userId is string &&
                       isValidString(request.resource.data.description, 500) &&
                       (!('amount' in request.resource.data) ||
                        (request.resource.data.amount is number &&
                         request.resource.data.amount >= -10000000000 &&
                         request.resource.data.amount <= 10000000000)));
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ========================================================
    // 🏛️ 정부 설정 (governmentSettings)
    // ========================================================
    match /governmentSettings/{classCode} {
      allow read: if isSameClassFast(classCode);
      allow write: if isAdmin();
    }

    // 🏛️ 정부 문서 (governments) — 아바타 상점 학급별 가격 override 등.
    //   클라이언트는 읽기만(같은 학급), 쓰기는 Cloud Function(admin) 전용.
    match /governments/{classCode} {
      allow read: if isSameClassFast(classCode);
      allow write: if isAdmin();
    }

    // ========================================================
    // 🏦 국고 (nationalTreasuries)
    // ========================================================
    match /nationalTreasuries/{classCode} {
      allow read: if isSameClassFast(classCode);
      allow write: if isAdmin();
    }

    // ========================================================
    // 🏦 은행 상품 설정 (bankingSettings)
    // ========================================================
    match /bankingSettings/{classCode} {
      allow read: if isSameClassFast(classCode);
      allow write: if isAdmin();
    }

    // ========================================================
    // 🎁 기부 기록 (donations)
    // ========================================================
    match /donations/{donationId} {
      allow read: if isSameClassFast(resource.data.classCode) || isAdminFast();
      allow create: if isSignedIn() && isOwner(request.resource.data.donorId);
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ========================================================
    // ⚖️ 정산 기록 (settlements)
    // ========================================================
    match /settlements/{settlementId} {
      allow read: if isSameClassFast(resource.data.classCode) || isAdminFast();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ========================================================
    // 🏘️ 부동산 (realEstate)
    // ========================================================
    match /realEstate/{propertyId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isOwner(resource.data.ownerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ========================================================
    // ⚖️ 재판 (trials)
    // ========================================================
    match /trials/{trialId} {
      allow read: if isSameClassFast(resource.data.classCode) || isAdminFast();
      allow create: if isSignedIn();
      allow update: if isAdmin(); // 재판 진행은 관리자만
      allow delete: if isAdmin();
    }

    // ========================================================
    // 🎯 경매 (auctions)
    // ========================================================
    match /auctions/{auctionId} {
      allow read: if isSignedIn();
      // 본인 학급 경매만 생성 가능 (타 학급 경매 생성 방지)
      allow create: if isSignedIn() && request.resource.data.classCode == getUserClassCode();
      allow update: if isSignedIn() &&
                       (isSameClass(resource.data.classCode) || isAdmin());
      allow delete: if isOwner(resource.data.sellerId) || isAdmin();
    }

    match /auctions/{auctionId}/bids/{bidId} {
      allow read: if isSameClassFast(get(/databases/$(database)/documents/auctions/$(auctionId)).data.classCode);
      allow create: if isSignedIn() && isOwner(request.resource.data.userId);
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ========================================================
    // 📚 학습 자료 (learningMaterials)
    // ========================================================
    match /learningMaterials/{materialId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ========================================================
    // 🎵 음악 요청 (musicRequests)
    // ========================================================
    match /musicRequests/{requestId} {
      allow read: if isSameClassFast(resource.data.classCode) || isAdminFast();
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.requesterId) || isAdmin();
      allow delete: if isOwner(resource.data.requesterId) || isAdmin();
    }

    // ========================================================
    // 🎮 게임 (games - 오목, 장기, 체스 등)
    // ========================================================
    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
                       (resource.data.player1 == request.auth.uid ||
                        resource.data.player2 == request.auth.uid ||
                        isAdmin());
      allow delete: if isAdmin();
    }

    // ========================================================
    // ♟️ 체스 게임 (chessGames)
    // ========================================================
    match /chessGames/{gameId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn() &&
                       (resource.data.players.white == request.auth.uid ||
                        resource.data.players.black == request.auth.uid ||
                        resource.data.aiMode == true ||
                        resource.data.status == "waiting" ||
                        isAdmin());
      allow delete: if isSignedIn() &&
                       (resource.data.players.white == request.auth.uid ||
                        resource.data.players.black == request.auth.uid ||
                        isAdmin());
    }

    // ========================================================
    // ⚫️ 오목 게임 (omokGames)
    // ========================================================
    match /omokGames/{gameId} {
      allow read, create: if isSignedIn();
      // 이미 플레이어이거나, 대기 중인 방에 입장하려는 경우(join), 또는 관리자
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.players.keys() ||
        resource.data.gameStatus == "waiting" ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (resource.data.host == request.auth.uid || isAdmin());
    }

    // ========================================================
    // 🎮 고누 게임 (gonuGames)
    // ========================================================
    match /gonuGames/{gameId} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn() &&
                       (resource.data.players.B == request.auth.uid ||
                        resource.data.players.W == request.auth.uid ||
                        isAdmin());
      allow delete: if isSignedIn() &&
                       (resource.data.players.B == request.auth.uid ||
                        resource.data.players.W == request.auth.uid ||
                        isAdmin());
    }

    // ========================================================
    // 📊 통계 (system_stats)
    // ========================================================
    match /system_stats/{statId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ========================================================
    // 🔴 에러 로그 (errorLogs) - SuperAdmin 전용
    // ========================================================
    match /errorLogs/{logId} {
      // 읽기: SuperAdmin만
      allow read: if isSuperAdminFast();
      // 쓰기: 모든 로그인 사용자 (에러 발생 시 자동 기록) 또는 SuperAdmin
      allow create: if isSignedIn();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ========================================================
    // 🚨 경찰서 (policeReports)
    // ========================================================
    match /policeReports/{reportId} {
      allow read: if isSameClassFast(resource.data.classCode) || isAdminFast();
      allow create: if isAdmin() ||
                       (isSameClass(request.resource.data.classCode) && policeReportCreateValid());
      allow update: if isAdmin() ||
                       (isSameClass(resource.data.classCode) && policeReportIdentityFrozen());
      allow delete: if isAdmin();
    }

    // ========================================================
    // 🏛️ 국회 (legislations)
    // ========================================================
    match /legislations/{legislationId} {
      allow read: if isSameClassFast(resource.data.classCode);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /legislations/{legislationId}/votes/{voteId} {
      allow read: if isSameClassFast(get(/databases/$(database)/documents/legislations/$(legislationId)).data.classCode);
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ========================================================
    // 🎫 주차권 (parkingTickets)
    // ========================================================
    match /parkingTickets/{ticketId} {
      allow read: if isOwner(resource.data.userId) || isAdminFast();
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ========================================================
    // 📋 조직도 (organizationChart)
    // ========================================================
    match /organizationChart/{classCode} {
      allow read: if isSameClassFast(classCode);
      allow write: if isAdmin();
    }

    // ========================================================
    // 💼 직업 (jobs)
    // ========================================================
    match /jobs/{jobId} {
      // 읽기: 로그인한 사용자, classCode 쿼리 허용
      allow read: if isSignedIn();
      // 쓰기: 관리자만
      allow write: if isAdmin();
    }

    // ========================================================
    // 📝 공통 할일 (commonTasks)
    // ========================================================
    match /commonTasks/{taskId} {
      // 읽기: 로그인한 사용자, classCode 쿼리 허용
      allow read: if isSignedIn();
      // 쓰기: 관리자만
      allow write: if isAdmin();
    }

    // ========================================================
    // 🎯 과제 (tasks)
    // ========================================================
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ========================================================
    // ⚙️ 전역 설정 (settings)
    // ========================================================
    // 거절된 선생님 이메일 목록 — 슈퍼관리자만 write (학급 관리자 차단)
    match /Settings/rejectedTeachers {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /Settings/{documentId} {
      allow read: if isSignedIn();
      // activeStatus는 로그인한 모든 사용자가 업데이트 가능 (주식 스케줄러 트리거용)
      allow write: if isAdmin() || (isSignedIn() && documentId == 'activeStatus');
    }

    // settings (소문자) - classCodes 등
    match /settings/{documentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ========================================================
    // 💰 세금 설정 (taxSettings)
    // ========================================================
    match /taxSettings/{classCode} {
      // 읽기: 로그인한 사용자 (주식 거래 시 세율 확인용)
      allow read: if isSignedIn();
      // 쓰기: 관리자만
      allow write: if isAdmin();
    }

    // ========================================================
    // 🎯 학급 목표 (goals)
    // ========================================================
    match /goals/{goalId} {
      // 읽기: 로그인한 모든 사용자 (목표 확인용)
      allow read: if isSignedIn();

      // 생성: 관리자만
      allow create: if isAdmin();

      // 수정: 기부 관련 필드만 일반 사용자 수정 가능, 나머지는 관리자만
      allow update: if isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['progress', 'donations', 'currentAmount', 'updatedAt']));

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ========================================================
    // 🏫 Class 컬렉션 (대문자 - 실제 학급 데이터)
    // SuperAdmin은 모든 학급 조회 가능
    // ========================================================
    match /Class/{classCode} {
      // 읽기: 같은 학급 또는 관리자 (타 학급 학생 명단 노출 방지)
      allow read: if isSameClassFast(classCode) || isAdminFast();
      // 쓰기: 관리자 또는 SuperAdmin
      allow write: if isAdmin() || isSuperAdmin();

      // 학생 서브컬렉션
      match /students/{studentId} {
        // 읽기: 같은 학급 또는 관리자
        allow read: if isSameClassFast(classCode) || isAdminFast();
        // 쓰기: 관리자 또는 SuperAdmin
        allow write: if isAdmin() || isSuperAdmin();
      }
    }

    // ========================================================
    // 🏫 학급 데이터 (classes - 소문자)
    // ========================================================
    match /classes/{classCode} {
      allow read: if isSameClassFast(classCode) || isAdminFast();
      allow write: if isAdmin();

      // 📚 학습 게시판 서브컬렉션 (classes/{classCode}/learningBoards/{boardId})
      match /learningBoards/{boardId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();

        // 게시글 서브컬렉션 (classes/{classCode}/learningBoards/{boardId}/posts/{postId})
        match /posts/{postId} {
          allow read: if isSameClassFast(classCode) || isAdminFast();
          allow create: if isSignedIn() && isSameClass(classCode);
          allow update: if isSignedIn() && isSameClass(classCode);
          allow delete: if isOwner(resource.data.authorId) || isAdmin();

          // 댓글 서브컬렉션
          match /comments/{commentId} {
            allow read: if isSameClassFast(classCode) || isAdminFast();
            allow create: if isSignedIn() && isSameClass(classCode);
            allow delete: if isOwner(resource.data.authorId) || isAdmin();
          }
        }
      }

      // 🧱 담벼락 (개인 게시판) — classes/{classCode}/personalBoards/{ownerId}
      // 문서 ID = 소유 학생 uid. visibility: 'private'(주인+교사만) | 'class'(같은 반 전체 열람·댓글)
      // 주의: *Fast 헬퍼는 read 전용. 학급공개 판의 글/댓글 읽기·쓰기는 부모 판 문서의
      // visibility를 get()으로 확인(비공개 판은 문서 부재→get 오류→자동 거부, 주인/교사는 그 전에 단락).
      match /personalBoards/{ownerId} {
        allow read: if isOwner(ownerId) || isAdminFast() ||
                       (isSameClassFast(classCode) && resource.data.get('visibility', 'private') == 'class');
        // 생성: 주인 학생 본인(비공개로만) 또는 교사. 학생이 스스로 학급공개로 만들지 못하게 강제.
        allow create: if (isOwner(ownerId) && request.resource.data.get('visibility', 'private') == 'private') || isAdmin();
        // 공개범위 변경 등 수정·삭제: 교사만
        allow update: if isAdmin();
        allow delete: if isAdmin();

        // 글: 주인 학생이 자기 담벼락에 작성(교사도 가능)
        // 쓰기 시 authorId는 본인 uid로 강제, isTeacher는 실제 교사만 true 가능(사칭 차단), 길이 상한.
        match /posts/{postId} {
          allow read: if isOwner(ownerId) || isAdminFast() ||
                         (isSameClassFast(classCode) &&
                          get(/databases/$(database)/documents/classes/$(classCode)/personalBoards/$(ownerId)).data.get('visibility', 'private') == 'class');
          allow create: if (isOwner(ownerId) || isAdmin()) &&
                           request.resource.data.authorId == request.auth.uid &&
                           (request.resource.data.get('isTeacher', false) == false || isAdmin()) &&
                           isValidString(request.resource.data.content, 2000);
          allow update: if isOwner(resource.data.authorId) || isAdmin();
          allow delete: if isOwner(resource.data.authorId) || isAdmin();

          // 댓글: 교사 + 판 주인 학생 + (학급공개면 같은 반 전체)
          match /comments/{commentId} {
            allow read: if isOwner(ownerId) || isAdminFast() ||
                           (isSameClassFast(classCode) &&
                            get(/databases/$(database)/documents/classes/$(classCode)/personalBoards/$(ownerId)).data.get('visibility', 'private') == 'class');
            allow create: if (isAdmin() || isOwner(ownerId) ||
                             (isSameClass(classCode) &&
                              get(/databases/$(database)/documents/classes/$(classCode)/personalBoards/$(ownerId)).data.get('visibility', 'private') == 'class')) &&
                             request.resource.data.authorId == request.auth.uid &&
                             (request.resource.data.get('isTeacher', false) == false || isAdmin()) &&
                             isValidString(request.resource.data.content, 1000);
            allow delete: if isOwner(resource.data.authorId) || isAdmin();
          }
        }
      }

      // 🎵 음악 요청 서브컬렉션 (classes/{classCode}/musicRequests/{requestId})
      match /musicRequests/{requestId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow create: if isSignedIn() && isSameClass(classCode);
        allow update: if isSignedIn() && isSameClass(classCode);
        allow delete: if isOwner(resource.data.requesterId) || isAdmin();
      }

      // 부동산 서브컬렉션
      match /realEstateProperties/{propertyId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow write: if isAdmin();
      }

      // 부동산 설정 서브컬렉션
      match /realEstateSettings/{settingsDoc} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow write: if isAdmin();
      }

      // 부동산 가격 제시(흥정) 서브컬렉션 — 쓰기는 Cloud Function(admin SDK)만
      match /realEstateOffers/{offerId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow write: if false;
      }

      // 🎯 경매 서브컬렉션 (classes/{classCode}/auctions/{auctionId})
      match /auctions/{auctionId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow create: if isSignedIn() && isSameClass(classCode);
        allow update: if isSignedIn() && isSameClass(classCode);
        allow delete: if isAdmin();

        // 입찰 서브컬렉션
        match /bids/{bidId} {
          allow read: if isSameClassFast(classCode) || isAdminFast();
          allow create: if isSignedIn() && isSameClass(classCode);
          allow update: if false;
          allow delete: if isAdmin();
        }
      }

      // 🏛️ 국회 법안 서브컬렉션 (classes/{classCode}/nationalAssemblyLaws/{lawId})
      match /nationalAssemblyLaws/{lawId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow create: if isSignedIn() && (isSameClass(classCode) || isAdmin());
        allow update: if isSignedIn() && (isSameClass(classCode) || isAdmin());
        allow delete: if isAdmin();
      }

      // 🏛️ 국회 설정 서브컬렉션 (classes/{classCode}/nationalAssemblySettings/{document})
      match /nationalAssemblySettings/{document} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow write: if isAdmin();
      }

      // 🗳️ 사용자 투표 기록 서브컬렉션 (classes/{classCode}/userVotes/{userId})
      match /userVotes/{userId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
        allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
        allow delete: if isAdmin();
      }

      // 🏦 국고 서브컬렉션 (classes/{classCode}/treasury/{document})
      match /treasury/{document} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow write: if isAdmin();
      }

      // 💰 국고 거래 내역 서브컬렉션 (classes/{classCode}/treasuryTransactions/{transactionId})
      match /treasuryTransactions/{transactionId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow create: if isAdmin();
        allow update: if false; // 거래 내역은 수정 불가
        allow delete: if isAdmin();
      }

      // 🚨 경찰서 신고 서브컬렉션 (classes/{classCode}/policeReports/{reportId})
      match /policeReports/{reportId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow create: if isAdmin() ||
                         (isSignedIn() && isSameClass(classCode) && policeReportCreateValid());
        allow update: if isAdmin() ||
                         (isSignedIn() && isSameClass(classCode) && policeReportIdentityFrozen());
        allow delete: if isAdmin();
      }

      // 🚨 경찰서 신고 사유 서브컬렉션 (classes/{classCode}/policeReportReasons/{document})
      match /policeReportReasons/{document} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow write: if isAdmin();
      }

      // ⚖️ 법원 고소장 서브컬렉션 (classes/{classCode}/courtComplaints/{complaintId})
      match /courtComplaints/{complaintId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow create: if isSignedIn() && isSameClass(classCode);
        allow update: if isSignedIn() && isSameClass(classCode);
        allow delete: if isAdmin();
      }

      // ⚖️ 재판방 서브컬렉션 (classes/{classCode}/trialRooms/{roomId})
      match /trialRooms/{roomId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow create: if isSignedIn() && isSameClass(classCode);
        allow update: if isSignedIn() && isSameClass(classCode);
        allow delete: if isAdmin();

        // 재판방 메시지 서브컬렉션
        match /messages/{messageId} {
          allow read: if isSameClassFast(classCode) || isAdminFast();
          allow create: if isSignedIn() && isSameClass(classCode);
          allow update: if false;
          allow delete: if isAdmin();
        }

        // 재판방 증거 자료 서브컬렉션
        match /evidence/{evidenceId} {
          allow read: if isSameClassFast(classCode) || isAdminFast();
          allow create: if isSignedIn() && isSameClass(classCode);
          allow update: if false; // 증거는 수정 불가
          allow delete: if isAdmin();
        }

        // 재판방 투표 서브컬렉션
        match /voting/{votingId} {
          allow read: if isSameClassFast(classCode) || isAdminFast();
          allow create: if isSignedIn() && isSameClass(classCode);
          allow update: if isSignedIn() && isSameClass(classCode);
          allow delete: if isAdmin();
        }
      }

      // ⚖️ 재판 결과 서브컬렉션 (classes/{classCode}/trialResults/{resultId})
      match /trialResults/{resultId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow create: if isSignedIn() && isOwner(request.resource.data.judgeId);
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      // 🔥 활동 로그 서브컬렉션 (classes/{classCode}/activityLogs/{logId})
      match /activityLogs/{logId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow create: if isSignedIn() && isSameClass(classCode);
        allow update: if false;
        allow delete: if isAdmin();
      }

      // 📊 마켓 요약 서브컬렉션 (classes/{classCode}/marketSummary/{document})
      match /marketSummary/{document} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow write: if isAdmin();
      }
    }

    // ========================================================
    // 💳 국세청 (taxRecords)
    // ========================================================
    match /taxRecords/{recordId} {
      allow read: if isOwner(resource.data.userId) || isAdminFast();
      // 본인 userId와 일치하는 세금 기록만 생성 가능 (타인 세금 기록 위조 방지)
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ========================================================
    // 💰 국고 (treasury) - 루트 레벨
    // ========================================================
    match /treasury/{classCode} {
      // 읽기: 같은 학급 또는 관리자
      allow read: if isSameClassFast(classCode) || isAdminFast();

      // 생성: 관리자 또는 같은 학급 사용자 (초기 생성 시)
      allow create: if isAdmin() || isSameClass(classCode);

      // 수정: 관리자 또는 같은 학급 사용자 (세금 납부, 금고 입출금 시)
      allow update: if isAdmin() || isSameClass(classCode);

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ========================================================
    // 💰 국고 (nationalTreasuries) - 추가된 규칙
    // ========================================================
    match /nationalTreasuries/{classCode} {
      // 읽기: 같은 학급 또는 관리자
      allow read: if isSameClassFast(classCode) || isAdminFast();

      // 생성: 관리자 또는 같은 학급 사용자 (초기 생성 시)
      allow create: if isAdmin() || isSameClass(classCode);

      // 수정: 관리자 또는 같은 학급 사용자 (금고 입출금 시)
      allow update: if isAdmin() || isSameClass(classCode);

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ========================================================
    // 💳 거래 기록 (transactions) - 루트 레벨
    // ========================================================
    match /transactions/{transactionId} {
      // 읽기: 본인 거래 또는 관리자
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminFast());

      // 생성: 로그인한 사용자 (자신의 거래만)
      allow create: if isSignedIn();

      // 수정: 임시: 이름 교체용
      allow update: if isAdmin();

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ========================================================
    // 🎵 음악 신청방 (musicRooms)
    // ========================================================
    match /musicRooms/{roomId} {
      // 읽기: 같은 학급 또는 관리자 (학급 격리)
      //   기존 데이터(classCode 없음)도 허용해 하위 호환 유지 — 마이그레이션 후 좁힐 수 있음
      allow read: if isSignedIn() && (
        resource.data.get('classCode', null) == null ||
        isSameClassFast(resource.data.classCode) ||
        isAdminFast()
      );

      // 생성: 관리자(선생님) + 본인 teacherId + classCode 본인 학급 강제
      allow create: if isAdmin() &&
                       isOwner(request.resource.data.teacherId) &&
                       isSameClass(request.resource.data.classCode);

      // 수정: 방 생성자 또는 관리자
      allow update: if isOwner(resource.data.teacherId) || isAdmin();

      // 삭제: 방 생성자 또는 관리자
      allow delete: if isOwner(resource.data.teacherId) || isAdmin();

      // 재생목록 서브컬렉션 (musicRooms/{roomId}/playlist/{songId})
      match /playlist/{songId} {
        // 읽기: 로그인한 모든 사용자 (학생들도 자신의 신청곡 확인)
        allow read: if isSignedIn();

        // 생성: 로그인한 모든 사용자 (학생들의 음악 신청)
        allow create: if isSignedIn();

        // 수정: 방 생성자 또는 관리자만
        allow update: if isOwner(get(/databases/$(database)/documents/musicRooms/$(roomId)).data.teacherId) || isAdmin();

        // 삭제: 방 생성자 또는 관리자만 (재생 완료 시)
        allow delete: if isOwner(get(/databases/$(database)/documents/musicRooms/$(roomId)).data.teacherId) || isAdmin();
      }
    }

    // ========================================================
    // 🔎 YouTube 검색 공유 캐시 (youtubeSearchCache)
    //    학급 전체가 검색 결과를 공유해 YouTube Data API quota(검색 100units/회)를 절약.
    //    민감정보 없음(공개 영상 메타데이터) → 로그인 사용자면 읽기/기록 허용.
    // ========================================================
    match /youtubeSearchCache/{queryId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ========================================================
    // 🏪 개인 상점 (personalShops)
    // ========================================================
    match /personalShops/{shopId} {
      // 읽기: 같은 학급만. classCode 없는 기존 문서는 하위 호환 허용
      allow read: if isSignedIn() && (
        resource.data.get("classCode", null) == null ||
        isSameClassFast(resource.data.classCode) ||
        isAdminFast()
      );

      // 생성: 본인 상점만
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // 수정: 본인/관리자는 전체, 같은 학급 구매자는 매출 관련 필드만
      allow update: if isOwner(resource.data.ownerId) || isAdmin() ||
                       (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalSales', 'totalTaxPaid', 'updatedAt']));

      // 삭제: 본인 또는 관리자
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // ========================================================
    // 📦 상점 상품 (shopProducts)
    // ========================================================
    match /shopProducts/{productId} {
      // 읽기: 같은 학급만. classCode 없는 기존 문서는 하위 호환 허용
      allow read: if isSignedIn() && (
        resource.data.get("classCode", null) == null ||
        isSameClassFast(resource.data.classCode) ||
        isAdminFast()
      );

      // 생성: 상점 소유자
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // 수정: 상품 소유자/관리자는 전체 수정, 구매자는 재고/판매 관련 필드만
      // status는 'soldout'으로만 변경 가능 (재고 0 시 자동 마킹) — 사보타주 방지
      // 🔒 [보안] 구매자 분기에 같은-학급 조건 추가: 개인상점은 학급 내 거래이므로
      //    정당 구매자는 항상 같은 학급. 타 학급 사용자의 재고/구매자목록 무단 조작 차단.
      allow update: if isOwner(resource.data.ownerId) || isAdmin() ||
                       (isSignedIn() &&
                        (resource.data.get('classCode', null) == null ||
                         isSameClassFast(resource.data.classCode)) &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'soldCount', 'buyers', 'status', 'updatedAt']) &&
                        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']) ||
                         request.resource.data.status == 'soldout'));

      // 삭제: 상품 소유자 또는 관리자
      allow delete: if isOwner(resource.data.ownerId) || isAdmin();
    }

    // ========================================================
    // 📜 활동 기록 (activities)
    // ========================================================
    match /activities/{activityId} {
      // 읽기: 거래 당사자(구매자/판매자) 본인 또는 관리자만 (이름 등 개인정보 보호)
      allow read: if isOwner(resource.data.buyerId) || isOwner(resource.data.sellerId) || isAdminFast();

      // 생성: 로그인한 사용자
      allow create: if isSignedIn();

      // 수정: 불가
      allow update: if false;

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ========================================================
    // 💰 국세청 (nationalTax)
    // ========================================================
    match /nationalTax/{docId} {
      // 읽기: 로그인한 사용자
      allow read: if isSignedIn();

      // 생성: 관리자
      allow create: if isAdmin();

      // 수정: 관리자 전체 수정, 일반 사용자는 세금 납부 관련 필드만
      allow update: if isAdmin() || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['payments', 'totalPaid', 'lastPaidAt', 'updatedAt']));

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ========================================================
    // ⚡ 경제 이벤트 - 활성 이벤트 팝업 (activeEconomicEvent)
    // 클라우드 함수가 쓰기, 같은 학급 사용자가 읽기 (팝업 표시용)
    // ========================================================
    match /activeEconomicEvent/{classCode} {
      allow read: if isSameClassFast(classCode) || isAdminFast();
      allow write: if isAdmin();
    }

    // ========================================================
    // ⚡ 경제 이벤트 설정 (economicEventSettings)
    // ========================================================
    match /economicEventSettings/{classCode} {
      allow read: if isSameClassFast(classCode) || isAdminFast();
      allow write: if isAdmin();
    }

    // ========================================================
    // 📋 경제 이벤트 로그 (economicEventLogs)
    // ========================================================
    match /economicEventLogs/{classCode} {
      allow read: if isSameClassFast(classCode) || isAdminFast();
      allow write: if isAdmin();

      match /entries/{entryId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow write: if isAdmin();
      }
    }

    // ========================================================
    // ✅ 보너스 할일 승인 요청 (pendingApprovals)
    // ========================================================
    match /pendingApprovals/{approvalId} {
      allow read: if isSignedIn() && (isSameClassFast(resource.data.classCode) || isAdminFast());
      // 본인 userId와 본인 classCode로만 생성 가능
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.classCode == getUserClassCode();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ========================================================
    // 📜 법안 (laws) - 국회/조직도에서 사용
    // ========================================================
    match /laws/{lawId} {
      allow read: if isSignedIn() && (isSameClassFast(resource.data.classCode) || isAdminFast());
      // 본인 학급 법안만 생성 가능
      allow create: if isSignedIn() && (request.resource.data.classCode == getUserClassCode() || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ========================================================
    // 🛍️ 마켓 리스팅 (marketListings) - CF가 작성, 클라이언트 읽기
    // ========================================================
    match /marketListings/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(resource.data.sellerId) || isAdmin());
      allow delete: if isOwner(resource.data.sellerId) || isAdmin();
    }

    // ========================================================
    // 💬 마켓 오퍼 (marketOffers) - CF가 작성, 클라이언트 읽기
    // ========================================================
    match /marketOffers/{offerId} {
      allow read: if isSignedIn();
      // 본인 buyerId로만 오퍼 생성 가능
      allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
      // 본인 오퍼이거나 판매자인 경우만 수정 가능
      allow update: if isSignedIn() && (isOwner(resource.data.buyerId) || isOwner(resource.data.sellerId) || isAdmin());
      allow delete: if isOwner(resource.data.buyerId) || isAdmin();
    }

    // ========================================================
    // ⚙️ 학급 설정 (classSettings) - CF가 읽기/쓰기
    // ========================================================
    match /classSettings/{classCode} {
      allow read: if isSameClassFast(classCode) || isAdminFast();
      allow write: if isAdmin();

      // 급여 등 세부 설정 서브컬렉션 (classSettings/{classCode}/settings/{settingId})
      match /settings/{settingId} {
        allow read: if isSameClassFast(classCode) || isAdminFast();
        allow write: if isAdmin();
      }
    }

    // ========================================================
    // 🤝 함께구매 (groupPurchases)
    // ========================================================
    match /groupPurchases/{purchaseId} {
      allow read: if isSignedIn() && isSameClassFast(resource.data.classCode);
      // 본인 initiatorId + 본인 classCode로만 생성
      allow create: if isSignedIn() &&
                       request.resource.data.initiatorId == request.auth.uid &&
                       request.resource.data.classCode == getUserClassCode();
      allow update: if isSignedIn() && isSameClass(resource.data.classCode);
      allow delete: if isOwner(resource.data.initiatorId) || isAdmin();
    }

    // ========================================================
    // 🔒 Rate Limit 컬렉션 (_rateLimits) - CF 내부 전용, 클라이언트 접근 차단
    // ========================================================
    match /_rateLimits/{docId} {
      allow read, write: if false; // Cloud Functions Admin SDK만 접근
    }

    // ========================================================
    // 🔒 스케줄러 락 (schedulerLocks) - CF 내부 전용
    // ========================================================
    match /schedulerLocks/{docId} {
      allow read, write: if false; // Cloud Functions Admin SDK만 접근
    }

    // ========================================================
    // 🚫 기타 모든 컬렉션은 기본적으로 차단
    // ========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
